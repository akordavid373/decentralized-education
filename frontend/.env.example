# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stellar Configuration
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_EDU_ISSUER=your-edu-token-issuer-public-key
NEXT_PUBLIC_EDU_TOKEN_CONTRACT_ID=your-edu-token-contract-id
NEXT_PUBLIC_BOUNTY_ESCROW_CONTRACT_ID=your-bounty-escrow-contract-id
NEXT_PUBLIC_REPUTATION_CONTRACT_ID=your-reputation-contract-id

# Stellar Horizon
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Wallet Support
NEXT_PUBLIC_ENABLE_FREIGHTER=true
NEXT_PUBLIC_ENABLE_ALBEDO=true

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_STELLAR=true
