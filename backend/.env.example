# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/decentralized_education"

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:3000

# Stellar Configuration
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=TESTNET
EDU_ISSUER_PUBLIC_KEY=your-edu-token-issuer-public-key
EDU_ISSUER_SECRET=your-edu-token-issuer-secret-key

# Stellar Smart Contracts
EDU_TOKEN_CONTRACT_ID=your-edu-token-contract-id
BOUNTY_ESCROW_CONTRACT_ID=your-bounty-escrow-contract-id
REPUTATION_CONTRACT_ID=your-reputation-contract-id

# Admin Accounts
ADMIN_SECRET=your-admin-secret-key
BOUNTY_ESCROW_ADMIN_SECRET=your-bounty-escrow-admin-secret
REPUTATION_ADMIN_SECRET=your-reputation-admin-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
